# ── Configuração do Sistema Palha ──────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores

# OBRIGATÓRIO — chave secreta para assinar os tokens JWT
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=mude-este-valor-para-uma-chave-forte-em-producao

# Tempo de expiração do token em minutos (padrão: 480 = 8 horas)
JWT_EXPIRE_MINUTES=480

# Senha do usuário admin criado automaticamente no primeiro deploy
# Após o primeiro login, altere via menu do sistema
DEFAULT_ADMIN_PASSWORD=palha@2025

# Porta exposta no host (padrão: 80)
APP_PORT=80
